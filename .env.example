# Delulu Detector — runtime config
# Copy to .env.local and fill in. Nothing here is committed (.env* is gitignored).

# Required for real verdicts. Without it, the app falls back to mock data
# (see the x-delulu-source: mock response header) so the UI still works end-to-end.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.5 (OpenAI's frontier model).
# OPENAI_MODEL=gpt-5.5

# Optional. Point at any OpenAI-compatible Chat Completions endpoint (fallback provider).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional. Absolute URL used by the /booth QR code. If unset, the QR uses the
# current origin at runtime (perfect once deployed to Vercel).
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
